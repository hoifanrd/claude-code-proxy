# Required API Keys
ANTHROPIC_API_KEY="your-anthropic-api-key" # Needed if proxying *to* Anthropic
OPENAI_API_KEY="sk-..."
GEMINI_API_KEY="your-google-ai-studio-key"

# Optional: Provider Preference and Model Mapping
# Controls which provider (google, openai, or anthropic) is preferred for mapping haiku/sonnet.
# Defaults to openai if not set.
# Set to "anthropic" for "just an Anthropic proxy" mode (no remapping)
PREFERRED_PROVIDER="openai"
OPENAI_BASE_URL="https://api.openai.com/v1"

# Tier mapping (Anthropic family -> backend model):
#   opus   -> BIG_MODEL    (highest tier)
#   sonnet -> SMALL_MODEL  (mid / daily-driver tier)
#   haiku  -> HAIKU_MODEL  (low tier; defaults to a free Gemini model)
# These are IGNORED when PREFERRED_PROVIDER=anthropic (models are not remapped).
# BIG_MODEL="gpt-4.1"
# SMALL_MODEL="gpt-4.1-mini"
# Low-tier model for Haiku. Defaults to Google's free Gemini Flash, the closest
# free analog to Claude Haiku. A gemini-* value requires GEMINI_API_KEY.
# Other free options: gemini-2.5-flash-lite, gemini-2.0-flash.
# HAIKU_MODEL="gemini-2.5-flash"

# Example Google mapping:
# PREFERRED_PROVIDER="google"
# BIG_MODEL="gemini-2.5-pro"
# SMALL_MODEL="gemini-2.5-flash"

# Example Google with vertex AI auth via ADC:
# PREFERRED_PROVIDER="google"
# USE_VERTEX_AUTH=true
# BIG_MODEL="gemini-2.5-pro"
# SMALL_MODEL="gemini-2.5-flash"

# Example "just an Anthropic proxy" mode:
# PREFERRED_PROVIDER="anthropic"
# (BIG_MODEL and SMALL_MODEL are ignored in this mode)

# --- Web search (Exa AI) ---------------------------------------------------
# Claude Code's WebSearch is a server-side tool. Since OpenAI-compatible
# backends (e.g. api.sakana.ai) cannot run it, the proxy executes the search
# itself via Exa AI and feeds the results back to the model.
# Get a key at https://dashboard.exa.ai . Web search is disabled if unset.
EXA_API_KEY="your-exa-api-key"
# Optional tuning:
# EXA_NUM_RESULTS=5            # results fetched per search
# EXA_TEXT_MAX_CHARS=2000      # max snippet characters per result
# WEB_SEARCH_MAX_USES=5        # max searches per request (loop safety cap)
# EXA_SEARCH_URL="https://api.exa.ai/search"
